# Central MenteMovimento - production placeholders
# Copy this file to .env.local only on your machine.
# In Vercel, add the real values in Project Settings > Environment Variables.

CENTRAL_PROJECT_NAME=central-mente-movimento
CENTRAL_ENV=production

# Supabase public values. These may be used by frontend code.
SUPABASE_URL=https://COLOQUE-O-PROJETO.supabase.co
SUPABASE_ANON_KEY=COLOQUE-A-ANON-KEY
VITE_SUPABASE_URL=https://COLOQUE-O-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=COLOQUE-A-ANON-KEY
NEXT_PUBLIC_SUPABASE_URL=https://COLOQUE-O-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=COLOQUE-A-ANON-KEY

# Server-only values. Never commit real values.
SUPABASE_SERVICE_ROLE_KEY=COLOQUE-APENAS-NA-VERCEL-OU-NO-ENV-LOCAL
SUPABASE_SECRET_KEY=COLOQUE-APENAS-NA-VERCEL-OU-NO-ENV-LOCAL
SUPABASE_BUCKET=documentos-utentes

# Local prototype fallback only. Replace before any real production use.
CENTRAL_EMAIL=admin@mentemovimento.local
CENTRAL_PASSWORD=trocar-em-producao
