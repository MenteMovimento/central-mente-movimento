{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/dashboard",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/login",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/area/socios",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/area/socios/",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/area/dispositivos",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/area/dispositivos/",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/area/utentes",
      "destination": "/api/utentes-app.py"
    },
    {
      "source": "/area/utentes/(.*)",
      "destination": "/api/utentes-app.py"
    },
    {
      "source": "/area/socios",
      "destination": "/area/socios/index.html"
    },
    {
      "source": "/area/socios/(.*)",
      "destination": "/area/socios/$1"
    },
    {
      "source": "/area/dispositivos",
      "destination": "/area/dispositivos/index.html"
    },
    {
      "source": "/area/dispositivos/(.*)",
      "destination": "/area/dispositivos/$1"
    },
    {
      "source": "/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/logout",
      "destination": "/logout.html"
    },
    {
      "source": "/historico",
      "destination": "/historico.html"
    },
    {
      "source": "/utilizadores",
      "destination": "/utilizadores.html"
    },
    {
      "source": "/manuais",
      "destination": "/manuais.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
